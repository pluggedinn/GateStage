{
  "name": "gatestage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=8080 NEXT_WS_URL=ws://127.0.0.1:9400 ESPHOME_MOCK_FLEET=1 tsx watch --exclude data/** server.ts",
    "dev:server": "PORT=8080 NEXT_WS_URL=ws://127.0.0.1:9400 ESPHOME_MOCK_FLEET=1 tsx server.ts",
    "build": "next build",
    "start": "NODE_ENV=production PORT=8080 tsx server.ts",
    "mock:next": "tsx mocks/next-ws-server.ts",
    "mock:esphome": "tsx mocks/esphome-mock-fleet.ts",
    "mock:esphome:single": "tsx mocks/esphome-mock-server.ts",
    "dev:mocks": "concurrently -k -n next,esphome,app -c blue,magenta,green \"npm run mock:next\" \"npm run mock:esphome\" \"npm run dev\"",
    "test:e2e": "playwright test",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "bonjour-service": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
